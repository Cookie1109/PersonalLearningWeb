APP_NAME=Personal Learning API
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8001
API_PREFIX=/api

DATABASE_URL=mysql+pymysql://root:root@localhost:3306/personal_learning
REDIS_URL=redis://localhost:6379/0

JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
