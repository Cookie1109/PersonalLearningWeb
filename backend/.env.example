APP_NAME=Personal Learning API
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8001
API_PREFIX=/api
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000,http://127.0.0.1:8000,https://personal-learning-web.vercel.app
CORS_ALLOW_ORIGIN_REGEX=^https://.*\.vercel\.app$
CORS_ALLOW_CREDENTIALS=true

DATABASE_URL=mysql+pymysql://root:root@localhost:3306/personal_learning
REDIS_URL=redis://localhost:6379/0

JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
REFRESH_COOKIE_NAME=refresh_token
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_PATH=
FIREBASE_CREDENTIALS_JSON=
FIREBASE_CHECK_REVOKED=false

IDEMPOTENCY_TTL_SECONDS=86400
LESSON_COMPLETE_REWARD_EXP=50
QUIZ_PASS_SCORE=80
QUIZ_PASS_REWARD_EXP=100
QUIZ_FIRST_PASS_REWARD_TYPE=quiz_first_pass
DAILY_QUEST_RESET_TIMEZONE=Asia/Ho_Chi_Minh
DAILY_QUEST_ALL_CLEAR_BONUS_EXP=100
GAMIFICATION_TRACK_READ_EXP_PER_UNIT=2
GAMIFICATION_TRACK_FLASHCARD_EXP_PER_UNIT=4
GAMIFICATION_TRACK_SUMMARY_EXP_PER_UNIT=30
QUIZ_COOLDOWN_FAIL_4_5_SECONDS=30
QUIZ_COOLDOWN_FAIL_6_PLUS_SECONDS=60
QUIZ_COOLDOWN_STATE_TTL_SECONDS=86400
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_QUIZ_MODEL=gemini-2.5-flash
GEMINI_PRO_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=120
YOUTUBE_API_KEY=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
