IDEMPOTENCY_TTL_SECONDS=86400
LESSON_COMPLETE_REWARD_EXP=50
QUIZ_PASS_SCORE=80
QUIZ_FIRST_PASS_REWARD_TYPE=quiz_first_pass
QUIZ_COOLDOWN_FAIL_4_5_SECONDS=30
QUIZ_COOLDOWN_FAIL_6_PLUS_SECONDS=60
QUIZ_COOLDOWN_STATE_TTL_SECONDS=86400
